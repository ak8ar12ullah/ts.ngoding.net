---
// src/components/CustomBreadcrumbs.astro
import { Breadcrumbs } from "astro-breadcrumbs";
import "astro-breadcrumbs/breadcrumbs.css";

// Ambil props dari Starlight
const { title = "null", kategori = "null" } = Astro.props;

// Kita definisikan struktur breadcrumbs secara manual agar lebih rapi
const customCrumbs = [
  { text: "Home", href: "https://ngoding.net" },
  { text: "Typescript", href: "/" }, 
  { text: kategori, href: `/${kategori}` }, 
  { text: title, href: "#" }, 
  
];
---

<div class="breadcrumb-container">
  <Breadcrumbs crumbs={customCrumbs}>
    <span slot="separator" class="sep">{">"}</span>
  </Breadcrumbs>
</div>

